# MemoFlow V3 环境变量模板 — 复制为 .env 后填入真实值

# LLM 配置（OpenAI 兼容接口 / LiteLLM）
LLM_BASE_URL=http://localhost:4000/v1
LLM_API_KEY=sk-your-key-here
MODEL_NAME=gemini-3.1-pro

# 数据库（默认 SQLite，生产环境用绝对路径并放持久化目录）
DATABASE_URL=sqlite:///memoflow_v3.db

# 服务配置
HOST=0.0.0.0
PORT=8000
DEBUG=false

# HTTP Basic Auth（两项都设置时启用；本地开发留空即关闭）
AUTH_USERNAME=
AUTH_PASSWORD=

# 前端构建产物目录（生产容器内为 /app/static；留空则不托管前端）
STATIC_DIR=
